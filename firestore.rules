rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function bootstrapExists() {
      return exists(/databases/$(database)/documents/system/bootstrap);
    }

    function bootstrapDoc() {
      return get(/databases/$(database)/documents/system/bootstrap);
    }

    function isPendingSelfSignup(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.role == 'pending'
        && request.resource.data.status == 'pending'
        && request.resource.data.approvedBy == null;
    }

    function isInitialOwnerSignup(uid) {
      return signedIn()
        && request.auth.uid == uid
        && bootstrapExists()
        && bootstrapDoc().data.ownerUid == uid
        && request.resource.data.uid == uid
        && request.resource.data.role == 'owner'
        && request.resource.data.status == 'approved'
        && request.resource.data.approvedBy == uid;
    }

    function isApproved() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc().data.status == 'approved' &&
        userDoc().data.role in ['owner', 'employee', 'technician'];
    }

    function isOwner() {
      return isApproved() && userDoc().data.role == 'owner';
    }

    function isEmployee() {
      return isApproved() && userDoc().data.role == 'employee';
    }

    function isTechnician() {
      return isApproved() && userDoc().data.role == 'technician';
    }

    match /system/bootstrap {
      allow read: if signedIn();
      allow create: if signedIn()
        && !bootstrapExists()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow create: if isPendingSelfSignup(uid) || isInitialOwnerSignup(uid);
      allow read: if (signedIn() && request.auth.uid == uid) || isOwner();
      allow update: if isOwner()
        || (request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.approvedBy == resource.data.approvedBy);
      allow delete: if false;
    }

    match /customers/{customerId} {
      allow read: if isOwner()
        || (isEmployee() && (
          resource.data.createdBy == request.auth.uid ||
          resource.data.assignedEmployeeId == request.auth.uid
        ));
      allow create: if isOwner() || isEmployee();
      allow update: if isOwner()
        || (isEmployee()
          && resource.data.createdBy == request.auth.uid
          && resource.data.syncStatus != 'synced');
      allow delete: if isOwner();
    }

    match /installations/{installationId} {
      allow read: if isOwner()
        || (isEmployee() && resource.data.createdBy == request.auth.uid);
      allow create: if isOwner() || isEmployee();
      allow update: if isOwner() || (isEmployee() && resource.data.createdBy == request.auth.uid);
      allow delete: if isOwner();
    }

    match /service_requests/{serviceId} {
      allow read: if isOwner()
        || (isTechnician() && resource.data.assignedTechnicianId == request.auth.uid);
      allow create: if isOwner();
      allow update: if isOwner()
        || (isTechnician()
          && resource.data.assignedTechnicianId == request.auth.uid
          && request.resource.data.customerId == resource.data.customerId
          && request.resource.data.installationId == resource.data.installationId
          && request.resource.data.assignedTechnicianId == resource.data.assignedTechnicianId
          && request.resource.data.serviceType == resource.data.serviceType
          && request.resource.data.createdBy == resource.data.createdBy);
      allow delete: if isOwner();
    }

    match /audit_logs/{logId} {
      allow read, write: if isOwner();
    }
  }
}
